NODUS_DOMAIN=nodus.example.org
NODUS_PUBLIC_URL=https://nodus.example.org
# Recommended: these two values create or update the administrator and skip /setup.
NODUS_ADMIN_EMAIL=admin@example.org
NODUS_ADMIN_PASSWORD=replace-with-a-long-unique-password
# Optional fallback: leave the administrator values empty and use /setup with a temporary token.
NODUS_SETUP_TOKEN=
